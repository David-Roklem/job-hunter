# ──────────────────────────────────────────────────────────────
# job_hunter — пример конфигурации окружения.
# Скопируйте в `.env` и заполните при необходимости:
#   cp .env.example .env
# Все ключи опциональны, кроме NODE_ENV и DATABASE_URL (есть значения
# по умолчанию). Валидация — в app/env.server.ts (zod).
# ──────────────────────────────────────────────────────────────

# Режим приложения: development | test | production
NODE_ENV=development

# Путь к SQLite-файлу. По умолчанию ./data/job_hunter.sqlite
# Директория создаётся автоматически при первом запуске.
DATABASE_URL=./data/job_hunter.sqlite

# Yandex GPT — генерация адаптированных резюме и сопроводительных писем.
# Получить ключ: https://yandex.cloud/ru/docs/yandexgpt/
# Включается в следующих фазах.
YANDEX_GPT_API_KEY=

# Telegram Bot Token — чтение каналов с вакансиями.
# Создать бота: @BotFather → /newbot → скопировать токен.
# Включается в следующих фазах.
TELEGRAM_BOT_TOKEN=
