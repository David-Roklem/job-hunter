# ──────────────────────────────────────────────────────────────
# job_hunter — пример конфигурации окружения.
# Скопируйте в `.env` и заполните при необходимости:
#   cp .env.example .env
# Все ключи опциональны, кроме NODE_ENV и DATABASE_URL (есть значения
# по умолчанию). Валидация — в app/env.server.ts (zod).
# ──────────────────────────────────────────────────────────────

# Режим приложения: development | test | production
NODE_ENV=development

# Путь к SQLite-файлу. По умолчанию ./data/job_hunter.sqlite
# Директория создаётся автоматически при первом запуске.
DATABASE_URL=./data/job_hunter.sqlite

# Z.AI (Zhipu AI) — генерация адаптированных резюме и сопроводительных писем.
# PRO-подписка. Получить ключ: https://docs.z.ai/ (console.z.ai).
ZAI_API_KEY=
# Модель (по умолчанию glm-5.2). Укажите, если PRO-подписка привязана к другой.
ZAI_MODEL=glm-5.2
# Base URL. По умолчанию — dedicated endpoint GLM Coding Plan (PRO-подписка):
# https://api.z.ai/api/coding/paas/v4. Для обычного аккаунта (pay-as-you-go)
# укажите https://api.z.ai/api/paas/v4. Через /chat/completions добавляется в коде.
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4

# Yandex GPT — резервный провайдер (не используется в фазе 04; оставлен для совместимости).
# Получить ключ: https://yandex.cloud/ru/docs/yandexgpt/
YANDEX_GPT_API_KEY=

# Telegram Bot Token — чтение каналов с вакансиями.
# Создать бота: @BotFather → /newbot → скопировать токен.
# Включается в следующих фазах.
TELEGRAM_BOT_TOKEN=

ZAI_API_KEY=
ZAI_MODEL=